# ============================================
# AI-Native Mini CRM - Environment Variables
# ============================================

# PostgreSQL connection string (Neon/Supabase compatible)
DATABASE_URL="postgresql://user:password@localhost:5432/minicrm?schema=public"

# Google Gemini API Key
GEMINI_API_KEY="your-gemini-api-key-here"

# Channel Service URL (where the CRM sends dispatch requests)
CHANNEL_SERVICE_URL="http://localhost:3001"

# CRM Callback URL (where the Channel Service posts delivery receipts)
CRM_CALLBACK_URL="http://localhost:3000"
